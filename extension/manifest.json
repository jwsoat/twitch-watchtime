{
  "manifest_version": 3,
  "name": "Twitch Watch Time Logger",
  "version": "0.2.0",
  "description": "Logs Twitch watch time to your own backend.",
  "permissions": ["storage", "alarms"],
  "host_permissions": [
    "https://www.twitch.tv/*",
    "https://*.twitch.tv/*",
    "https://player.twitch.tv/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.twitch.tv/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://player.twitch.tv/*"],
      "js": ["player.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_icon": { "128": "icon-128.png" },
    "default_title": "Twitch Watch Time"
  },
  "icons": {
    "128": "icon-128.png"
  }
}
